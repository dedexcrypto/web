---
import Section from './Section.astro';
---

<Section id="about">
    <div class="container">
        <div class="content">
            <h2 class="heading">About the project</h2>
            <p class="text">
                Fully decentralized derivatives exchange with a unique
                near-index price market-making algorithm. <br /><br />Currently,
                centralized trading systems may restrict and censor users —
                these systems lack anonymity and there is a risk of central
                authority mismanagement. But DEDEX introduces the solution to
                these issues.<br /><br /> Even more, DEDEX instills a DeFi
                revolution, empowered by the derivatives market, and offers
                unique products such as:
            </p>
            <div class="icons">
                <div class="product">
                    <div class="product-icon">
                        <img src="/bitcoin.svg" alt="bitcoin" />
                    </div>
                    <p class="description">
                        The first real representation of Bitcoin in the Ethereum
                        ecosystem
                    </p>
                </div>
                <div class="product">
                    <div class="icon">
                        <div class="product-icon">
                            <img src="/dollar.svg" alt="dollar" />
                        </div>
                    </div>
                    <p class="description">
                        Decentralized and non-over-collateralized stablecoin
                    </p>
                </div>
                <div class="product">
                    <div class="product-icon">
                        <img src="/card.svg" alt="card" />
                    </div>
                    <p class="description">
                        A stablecoin payment network & a cross-chain swap tool
                    </p>
                </div>
            </div>
        </div>
    </div>
</Section>

<style>
    .container {
        margin: 4.31rem 0 5rem 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .content {
        position: relative;
        display: flex;
        max-width: 71.625rem;
        flex-direction: column;
        justify-content: center;
    }
    .content::before {
        position: absolute;
        width: 3.06688rem;
        height: 2.55525rem;
        flex-shrink: 0;
        transform: translateY(15%);
        left: -5%;
        top: 0;
        content: url('/decoration.svg');
    }
    .heading {
        color: #001f3e;
        font-size: 3.125rem;
        font-family: Outfit;
        font-weight: 600;
    }
    .text {
        margin-top: 1rem;
        color: rgba(0, 31, 62, 0.6);
        font-size: 1rem;
        font-family: Manrope;
        font-weight: 500;
        line-height: 160%;
        letter-spacing: 0.01rem;
    }
    .icons {
        display: flex;
        margin-top: 3rem;
        gap: 4.375rem;
    }
    .product {
        display: flex;
        align-items: flex-start;
        gap: 1.25rem;
        align-self: stretch;
    }
    .product-icon {
        width: 3.75rem;
        height: 3.75rem;
        flex-shrink: 0;
        display: flex;
        justify-content: center;
        border-radius: 9999px;
        padding: 0.75rem;
        background: #ffcd19;
    }
    .description {
        color: #001f3e;
        font-size: 1.3125rem;
        font-family: Outfit;
        font-weight: 600;
        text-align: start;
    }
    @media (max-width: 790px) {
        .icons {
            flex-direction: column;
        }
        .product {
            align-items: center;
        }
    }
    @media (max-width: 1000px) {
        .icons {
            gap: 2rem;
        }
    }
    @media (max-width: 1280px) {
        .description {
            font-size: 1.125rem;
        }
        .content::before {
            display: none;
        }
        .heading {
            font-size: 2.25rem;
        }
        .icons {
            margin-top: 2.5rem;
        }
    }
</style>
